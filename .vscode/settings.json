{
    "editor.formatOnSave": true,
    "editor.defaultFormatter": null, 
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit" // isort
        }
    },
    
    "python.analysis.typeCheckingMode": "strict",


    "[markdown]": {
        "editor.defaultFormatter": "yzhang.markdown-all-in-one" 
    },
    "[yaml]": {
        "editor.defaultFormatter": "redhat.vscode-yaml" 
    },
    "[csv]": {
        "editor.defaultFormatter": "mechatroner.rainbow-csv" 
   },
    "cSpell.words": [
        "aalessandrini",
        "Alessandrini",
        "astream",
        "authtoken",
        "BUILDTAG",
        "caplog",
        "Cocoro",
        "cognitiveservices",
        "conver",
        "docstore",
        "dotenv",
        "fastapi",
        "gemini",
        "genai",
        "hashicorp",
        "HNSW",
        "Itaca",
        "iterrows",
        "jiwer",
        "levelname",
        "nullable",
        "openai",
        "pgvector",
        "postgres",
        "prerrequisitos",
        "provença",
        "samplerate",
        "Sants",
        "speechsdk",
        "twilio",
        "twiml",
        "ulaw",
        "Urquinaona",
        "venv",
        "websocket",
        "websockets",
        "wers",
        "westeurope"
    ],
    "cSpell.enabled": true, 
	"cSpell.language": "es,en", 
    "cSpell.dictionaries": [
        "spanish",
        "english"
    ],
    "python.testing.pytestArgs": [
        "tests"
    ],
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true
}
